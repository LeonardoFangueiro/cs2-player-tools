{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CS2 Player Tools",
  "version": "0.1.0",
  "identifier": "com.cs2playertools.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CS2 Player Tools",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.steampowered.com https://speed.cloudflare.com https://cloudflare-dns.com ipc: http://tauri.localhost; img-src 'self' data: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/wireguard/*": "wireguard/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
